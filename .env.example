# Google Sheets Configuration
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
CERTIFICATES_SHEET_NAME=CERTIFICATES

# Certificate Domain Routing
# Comma-separated hosts that should serve the certificate portal through middleware rewrites
CERTIFICATES_HOSTS=certificates.arkph.tech,www.certificates.arkph.tech
# Optional: force verification links to use this base URL in API responses
CERTIFICATES_BASE_URL=https://www.certificates.arkph.tech

# Admin Authentication
ADMIN_USERS=admin1:password1,admin2:password2
# OR use single admin (legacy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here

# Session Secret
SESSION_SECRET=your_random_secret_key_here
